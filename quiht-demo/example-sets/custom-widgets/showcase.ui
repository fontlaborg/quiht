<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>CustomWidgetShowcase</class>
 <widget class="QWidget" name="CustomWidgetShowcase">
  <property name="windowTitle"><string>Custom widget showcase</string></property>
  <layout class="QVBoxLayout" name="root">
   <property name="spacing"><number>10</number></property>
   <item>
    <widget class="QGroupBox" name="colorBox">
     <property name="title"><string>Colour controls</string></property>
     <layout class="QGridLayout" name="colorGrid">
      <item row="0" column="0"><widget class="YColorPreview" name="prev"/></item>
      <item row="0" column="1"><widget class="YColorButton" name="cbtn"/></item>
      <item row="0" column="2"><widget class="YColorRing" name="ring"/></item>
      <item row="1" column="0" colspan="3"><widget class="YHueBar" name="hue"/></item>
      <item row="2" column="0" colspan="3"><widget class="YGradientBar" name="grad"/></item>
      <item row="3" column="0" colspan="3"><widget class="YOpacityBar" name="opac"/></item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="dialBox">
     <property name="title"><string>Dials &amp; selectors</string></property>
     <layout class="QHBoxLayout" name="dialRow">
      <item><widget class="YAngle" name="angle"/></item>
      <item><widget class="YCenterSelector" name="center"/></item>
      <item><widget class="YSimpleSlider" name="slider"/></item>
      <item><widget class="YCheckButton" name="snap"/></item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="textBox">
     <property name="title"><string>Labels &amp; toggles</string></property>
     <layout class="QVBoxLayout" name="textCol">
      <item><widget class="YTitleLabel" name="title"><property name="text"><string>Section title</string></property></widget></item>
      <item><widget class="YIconCheckBox" name="icb"><property name="text"><string>Show overshoot</string></property></widget></item>
      <item><widget class="YLineEditSuffix" name="suffix"><property name="suffix"><string>upm</string></property></widget></item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="listBox">
     <property name="title"><string>Lists &amp; trees</string></property>
     <layout class="QHBoxLayout" name="listRow">
      <item>
       <widget class="YSelectableList" name="list">
        <item><property name="text"><string>Alpha</string></property></item>
        <item><property name="text"><string>Beta</string></property></item>
        <item><property name="text"><string>Gamma</string></property></item>
       </widget>
      </item>
      <item>
       <widget class="YSelectableTree" name="tree">
        <item>
         <property name="text"><string>Group</string></property>
         <item><property name="text"><string>Child one</string></property></item>
         <item><property name="text"><string>Child two</string></property></item>
        </item>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
  </layout>
 </widget>
