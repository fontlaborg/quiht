{
  "name": "quiht-l10n-vu",
  "version": "0.0.0",
  "description": "Three-pane Qt .ui localization reviewer SPA built on quiht-core. Loads .quiht.zip / .quiht.json / .ui datasets and shows source and translated strings in visual context.",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": [
    "qt",
    "ui",
    "localization",
    "l10n",
    "reviewer",
    "quiht"
  ],
  "homepage": "https://fontlab.org/quiht/",
  "repository": {
    "type": "git",
    "url": "https://github.com/fontlaborg/quiht.git",
    "directory": "quiht-l10n-vu"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "quiht-core": "file:../quiht-core"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
